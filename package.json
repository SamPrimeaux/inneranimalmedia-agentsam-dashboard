{
  "name": "iam-pty",
  "version": "1.0.1",
  "main": "server.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:report-upload": "playwright test && ./scripts/upload-playwright-report-to-r2.sh",
    "start": "node server.js",
    "deploy": "./scripts/with-cloudflare-env.sh npx wrangler deploy -c wrangler.production.toml",
    "generate:route-map": "node scripts/generate-route-map.js",
    "generate:d1-schema-doc": "node scripts/generate-d1-agentic-schema.js",
    "ingest:docs": "./scripts/with-cloudflare-env.sh node scripts/ingest-docs.js",
    "ingest:d1-memory": "./scripts/with-cloudflare-env.sh node scripts/ingest-d1-memory.js",
    "deploy:full": "./scripts/deploy-frontend.sh",
    "deploy:ingest": "npm run generate:route-map && npm run generate:d1-schema-doc && npm run ingest:docs && npm run ingest:d1-memory && ./scripts/with-cloudflare-env.sh npx wrangler deploy -c wrangler.production.toml",
    "promote:prod": "./scripts/promote-to-prod.sh",
    "smoke:ai": "node scripts/ai-smoke-report.mjs",
    "smoke:mcp": "node scripts/mcp-smoke.mjs",
    "d1:workflows-audit": "./scripts/with-cloudflare-env.sh npx wrangler d1 execute inneranimalmedia-business --remote -c wrangler.production.toml --file=./scripts/d1-workflows-audit.sql",
    "designstudio:check": "bash scripts/designstudio/local-check.sh",
    "designstudio:smoke": "bash scripts/designstudio/pipeline-smoke.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "@cloudflare/playwright": "^1.1.0",
    "@neondatabase/serverless": "^1.1.0",
    "aws4fetch": "^1.0.20",
    "node-pty": "^1.1.0",
    "pg": "^8.20.0",
    "prismjs": "^1.30.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "acorn": "^8.16.0",
    "acorn-jsx": "^5.3.2",
    "acorn-walk": "^8.3.5",
    "chrome-devtools-mcp": "^0.21.0",
    "wrangler": "^4.86.0"
  },
  "type": "module"
}
