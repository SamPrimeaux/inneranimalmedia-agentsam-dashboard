@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&display=swap');

/* Agent dashboard mount - shell provides dimensions */
#agent-dashboard-root {
  display: block;
  box-sizing: border-box;
}

/* Mode colors (Ask, Debug, Plan, Agent) - use var(--mode-*) in components */
#agent-dashboard-root {
  --mode-ask: #10b981;
  --mode-debug: #ef4444;
  --mode-plan: #f59e0b;
  --mode-agent: #3b82f6;
}

@keyframes modePulse {
  0%, 100% { opacity: 1; transform: translateY(-50%) scale(1); }
  50% { opacity: 0.6; transform: translateY(-50%) scale(1.15); }
}

/* Agent state colors (TOOL_CALL, CODE_GEN, QUEUED) - use var(--state-*) in components */
#agent-dashboard-root {
  --state-tool: #8b5cf6;
  --state-code: #06b6d4;
  --state-queued: #64748b;
  --mode-code: #06b6d4;
  --color-on-mode: #ffffff;
}

@keyframes blink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0; }
}

.agent-status-text {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  font-family: inherit;
  min-height: 20px;
  transition: opacity 500ms ease;
}

.agent-status-text .status-label {
  font-weight: 600;
  flex-shrink: 0;
}

.agent-status-text .status-cursor {
  animation: blink 1s step-end infinite;
  flex-shrink: 0;
}

* {
  box-sizing: border-box;
}

::-webkit-scrollbar {
  width: 4px;
  height: 4px;
}

::-webkit-scrollbar-track {
  background: #0a0c0f;
}

::-webkit-scrollbar-thumb {
  background: #1e2530;
  border-radius: 2px;
}

select option {
  background: #161b22;
}

@keyframes pulse {
  0%, 100% {
    opacity: 0.3;
    transform: scale(0.8);
  }
  50% {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Chat input container (Cursor-style) */
.agent-input-container {
  transition: border-color 200ms ease;
}
.agent-input-container:focus-within {
  border-color: var(--mode-color);
}
.agent-input-container textarea {
  font-family: inherit;
  line-height: 1.4;
}
.agent-input-container textarea::placeholder {
  color: var(--text-secondary);
  opacity: 0.6;
}
.add-files-btn:hover {
  background: var(--bg-canvas);
}
