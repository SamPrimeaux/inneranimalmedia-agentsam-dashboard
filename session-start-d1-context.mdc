### Quick audit queries
```sql
-- Token health (use input_tokens NOT total_input_tokens)
SELECT model_used, AVG(input_tokens) as avg_in, AVG(output_tokens) as avg_out,
  COUNT(*) as calls FROM agent_telemetry
WHERE created_at >= unixepoch()-3600 GROUP BY model_used ORDER BY avg_in DESC;

-- Spend (most reliable)
SELECT provider, model_key, SUM(amount_usd) as total, SUM(tokens_in) as total_in
FROM spend_ledger WHERE occurred_at >= unixepoch()-86400
GROUP BY provider, model_key ORDER BY total DESC;

-- Current benchmark status
SELECT id, status, notes FROM deployments ORDER BY created_at DESC LIMIT 3;

-- RAG ingest health (after first ingest)
SELECT object_key, token_count, chunk_count, embed_calls, status
FROM rag_ingest_log ORDER BY created_at DESC LIMIT 5;
```

