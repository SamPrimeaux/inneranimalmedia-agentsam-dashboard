# =============================================================================
# Local CLI only — copy to .env.cloudflare (gitignored). See scripts/with-cloudflare-env.sh
# =============================================================================
#
# This file lists NAMES for checklists. Do not put real secrets or production IDs here.
# Worker runtime secrets live in the Cloudflare dashboard (inneranimalmedia). Wrangler
# also merges [vars] from wrangler.production.toml (OAuth client IDs, account id, etc.).
#
# Before any deploy: open dashboard Variables & Secrets + Bindings and compare to
# wrangler.production.toml. Wrong -c file or a partial config can strand routes or
# leave the Worker missing bindings — fix in dashboard + toml, not by pasting secrets
# into git.
#
# Minimal values you actually set in .env.cloudflare for this repo’s scripts:
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# Direct Postgres URL for Supabase (same logical value as Worker secret SUPABASE_DB_URL; not readable from API)
SUPABASE_DB_URL=

# Optional — same names as Worker secrets; use for aws s3 / rclone sync to R2 only.
# Not interchangeable with CLOUDFLARE_API_TOKEN.
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# =============================================================================
# Dashboard — Plaintext vars (names only). Values belong in dashboard / wrangler [vars].
# =============================================================================
# CLOUDFLARE_ACCOUNT_ID
# CLOUDFLARE_IMAGES_ACCOUNT_HASH
# GITHUB_CLIENT_ID
# GOOGLE_CLIENT_ID
# TENANT_ID

