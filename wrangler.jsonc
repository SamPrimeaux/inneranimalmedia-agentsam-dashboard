// Cloudflare Workers Builds (Git integration) — sandbox worker only.
// Default URL: https://inneranimal-dashboard.meauxbility.workers.dev
//
// R2: cloned dashboard/static lives in agent-sam-sandbox-cidi. Worker code uses BOTH:
//   - ASSETS (index.html, public routes in inneranimalmedia-assets on prod)
//   - DASHBOARD (static/dashboard/*, auth-signin, uploads on prod → agent-sam)
// Bind BOTH to the same sandbox bucket so keys match worker.js lookups.
//
// D1: inneranimalmedia-business matches prod — full parity for CIDI/sandbox testing; writes from
// this worker affect production data. Use read-only tests or accept shared DB risk.
//
// Production deploy: ./scripts/with-cloudflare-env.sh npx wrangler deploy -c wrangler.production.toml
// (worker inneranimalmedia) with Sam approval — do not confuse with this file.
//
// Sandbox login (Worker secrets on inneranimal-dashboard only):
//   SANDBOX_DASHBOARD_PASSWORD (plain) or PBKDF2 pair; optional SANDBOX_DASHBOARD_LOGIN_EMAIL (default info@inneranimals.com).
//
// Do not put CLOUDFLARE_API_TOKEN in this file or as a Worker plaintext variable (wide blast radius).
// Use gitignored .env.cloudflare + scripts/with-cloudflare-env.sh for CLI only. Rotate any token that was pasted into chat/UI logs.

{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "inneranimal-dashboard",
  "main": "worker.js",
  "compatibility_date": "2026-01-20",
  "workers_dev": true,
  "preview_urls": true,
  "no_bundle": false,
  "build": {
    "command": ""
  },
  "r2_buckets": [
    {
      "binding": "ASSETS",
      "bucket_name": "agent-sam-sandbox-cidi"
    },
    {
      "binding": "DASHBOARD",
      "bucket_name": "agent-sam-sandbox-cidi"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "inneranimalmedia-business",
      "database_id": "cf87b717-d4e2-4cf8-bab0-a81268e32d49"
    }
  ],
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": true,
      "destinations": ["inneranimalmedia-selfhosted"],
      "persist": true,
      "head_sampling_rate": 1
    }
  },
  // Do not add wrangler "assets" here: it steals the ASSETS binding from R2 and breaks worker.js (blank /).
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
