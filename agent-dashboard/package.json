{
  "name": "agent-dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npx --yes madge --extensions js,jsx --circular src/main.jsx && vite build",
    "build:debug": "npx --yes madge --extensions js,jsx --circular src/main.jsx && VITE_AGENT_DASHBOARD_DEBUG=1 vite build",
    "build:vite-only": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "dompurify": "3.3.3",
    "monaco-editor": "0.55.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "vite": "^5.4.21",
    "vite-plugin-monaco-editor": "^1.1.0"
  }
}
