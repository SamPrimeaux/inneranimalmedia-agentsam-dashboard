import React, { useCallback, useEffect, useRef, useState } from "react";
import { Terminal } from "@xterm/xterm";
import { FitAddon } from "@xterm/addon-fit";
import { WebLinksAddon } from "@xterm/addon-web-links";
import "@xterm/xterm/css/xterm.css";

const BOTTOM_TABS = ["terminal", "output", "problems", "debug", "ports", "mcp", "quick"];

/** Normalize GET /api/agent/terminal/socket-url `url` to wss:// or ws:// (trim, https→wss). */
function normalizePtyWebSocketUrl(raw) {
  if (raw == null) return "";
  let u = String(raw).trim();
  if (!u) return "";
  if (/^https:\/\//i.test(u)) u = "wss://" + u.slice(8);
  else if (/^http:\/\//i.test(u)) u = "ws://" + u.slice(7);
  if (/^wss:\/\//i.test(u)) return "wss://" + u.replace(/^wss:\/\//i, "");
  if (/^ws:\/\//i.test(u)) return "ws://" + u.replace(/^ws:\/\//i, "");
  return "";
}

function formatQuickAt(iso) {
  if (!iso) return "Never";
  try {
    const d = new Date(iso);
    return d.toLocaleString(undefined, { month: "short", day: "numeric", hour: "2-digit", minute: "2-digit" });
  } catch (_) {
    return String(iso);
  }
}

function QuickSection({ title, children }) {
  return (
    <div style={{ border: "1px solid var(--border)", borderRadius: 8, padding: 10, background: "var(--bg-canvas)" }}>
      <div
        style={{
          fontSize: 10,
          textTransform: "uppercase",
          letterSpacing: "0.06em",
          color: "var(--text-secondary)",
          marginBottom: 10,
        }}
      >
        {title}
      </div>
      <div style={{ display: "flex", flexDirection: "column", gap: 8 }}>{children}</div>
    </div>
  );
}

function QuickRunMeta({ meta }) {
  if (!meta || !meta.at) {
    return <span style={{ fontSize: 10, color: "var(--text-muted)" }}>Never</span>;
  }
  return (
    <span style={{ fontSize: 10, color: "var(--text-muted)" }}>
      {formatQuickAt(meta.at)}
      <span
        style={{
          display: "inline-block",
          width: 6,
          height: 6,
          borderRadius: "50%",
          marginLeft: 6,
          verticalAlign: "middle",
          background:
            meta.ok === true
              ? "var(--color-primary)"
              : meta.ok === false
                ? "var(--color-error)"
                : "var(--text-muted)",
        }}
      />
    </span>
  );
}

function QuickActionRow({ label, last, busy, onRun, hint }) {
  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 4 }}>
      <div style={{ display: "flex", alignItems: "center", gap: 8, flexWrap: "wrap" }}>
        <span style={{ flex: 1, minWidth: 100, fontWeight: 500, color: "var(--text-primary)" }}>{label}</span>
        <QuickRunMeta meta={last} />
        <button
          type="button"
          disabled={busy}
          onClick={onRun}
          style={{
            padding: "4px 12px",
            fontSize: 11,
            borderRadius: 4,
            border: "1px solid var(--border)",
            background: "var(--accent)",
            color: "var(--bg-canvas)",
            cursor: busy ? "wait" : "pointer",
            fontFamily: "inherit",
            opacity: busy ? 0.7 : 1,
          }}
        >
          {busy ? "…" : "Run"}
        </button>
      </div>
      {hint ? (
        <div style={{ fontSize: 10, color: "var(--text-muted)", lineHeight: 1.35 }}>{hint}</div>
      ) : null}
    </div>
  );
}

export default function AgentBottomPanel({
  open,
  height,
  onHeightChange,
  activeTab,
  onTabChange,
  runCommandRunnerRef,
  onOpenBrowserPanel,
  onOpenSettingsVault,
  agentSessionId,
  workflowCollabRunId = null,
}) {
  const [terminalWsState, setTerminalWsState] = useState("idle");
  const [terminalInput, setTerminalInput] = useState("");
  const [terminalUserReconnect, setTerminalUserReconnect] = useState(0);
  const SHELL_PREF_KEY = "agent-terminal-shell-preference";
  const [shellMode, setShellMode] = useState(() => {
    if (typeof window === "undefined") return "remote";
    try {
      const v = localStorage.getItem(SHELL_PREF_KEY);
      return v === "local" ? "local" : "remote";
    } catch (_) {
      return "remote";
    }
  });
  const terminalWsRef = useRef(null);
  const xtermContainerRef = useRef(null);
  const xtermContainer2Ref = useRef(null);
  const terminalXtermRef = useRef(null);
  const terminalXterm2Ref = useRef(null);
  const terminalInputRef = useRef(null);
  const terminalSessionIdRef = useRef(null);
  const scrollRefs = useRef({});
  const scrollSaveTimers = useRef({});
  const mountedRef = useRef(true);
  const openRef = useRef(open);
  const activeTabRef = useRef(activeTab);
  const [mcpHealth, setMcpHealth] = useState(null);
  const [mcpLoading, setMcpLoading] = useState(false);
  const [mcpExpandedId, setMcpExpandedId] = useState(null);
  const [outputLog, setOutputLog] = useState([]);
  const [problemsState, setProblemsState] = useState({
    loading: false,
    data: null,
    error: null,
    lastChecked: null,
  });
  const [quickRun, setQuickRun] = useState({});
  const [mcpQuickServices, setMcpQuickServices] = useState([]);
  const [quickBusy, setQuickBusy] = useState(null);
  const [terminalSplitCount, setTerminalSplitCount] = useState(1);
  const [portsState, setPortsState] = useState({ text: "", loading: false, error: null, at: null });
  const [debugState, setDebugState] = useState({ rows: [], loading: false, error: null, at: null });

  const writeAllXterms = useCallback((data) => {
    const s = data != null ? String(data) : "";
    if (!s) return;
    [terminalXtermRef, terminalXterm2Ref].forEach((ref) => {
      const tt = ref.current;
      if (!tt) return;
      try {
        tt.write(s);
      } catch (_) {}
    });
  }, []);

  openRef.current = open;
  activeTabRef.current = activeTab;

  useEffect(() => () => {
    mountedRef.current = false;
  }, []);

  useEffect(() => {
    if (!workflowCollabRunId || typeof workflowCollabRunId !== "string") {
      return;
    }
    const wsProto = typeof window !== "undefined" && window.location.protocol === "https:" ? "wss:" : "ws:";
    const host = typeof window !== "undefined" ? window.location.host : "";
    const room = `workflow:${workflowCollabRunId}`;
    const url = `${wsProto}//${host}/api/collab/${encodeURIComponent(room)}`;
    setOutputLog([]);
    let ws = null;
    try {
      ws = new WebSocket(url);
    } catch (_) {
      setOutputLog((prev) => [...prev, "[workflow] Could not open collab WebSocket."]);
      return;
    }
    ws.onopen = () => {
      setOutputLog((prev) => [...prev, "[workflow] Listening for step updates..."]);
    };
    ws.onmessage = (ev) => {
      const raw = typeof ev.data === "string" ? ev.data : ev.data?.toString?.() ?? "";
      try {
        const p = JSON.parse(raw);
        if (p && p.type === "workflow_step") {
          const st = p.status != null ? String(p.status) : "?";
          const sn = p.stepNumber != null ? String(p.stepNumber) : "?";
          const name = p.stepName != null ? String(p.stepName) : "";
          const out = p.output != null ? String(p.output) : "";
          const ms = p.durationMs != null ? ` (${p.durationMs}ms)` : "";
          const line = `[${st}] Step ${sn}: ${name}${out ? ` — ${out}` : ""}${ms}`;
          setOutputLog((prev) => [...prev, line]);
        }
      } catch (_) {}
    };
    ws.onerror = () => {
      setOutputLog((prev) => [...prev, "[workflow] WebSocket error."]);
    };
    ws.onclose = () => {
      setOutputLog((prev) => [...prev, "[workflow] Collab connection closed."]);
    };
    return () => {
      try {
        ws?.close();
      } catch (_) {}
    };
  }, [workflowCollabRunId]);

  const persistScroll = useCallback((tab, el) => {
    if (!el) return;
    scrollRefs.current[tab] = el;
    const saved = sessionStorage.getItem(`iam_bottom_scroll_${tab}`);
    if (saved != null) {
      const y = parseInt(saved, 10);
      if (!Number.isNaN(y)) el.scrollTop = y;
    }
  }, []);

  const onScrollPane = useCallback((tab) => (e) => {
    const el = e.currentTarget;
    if (scrollSaveTimers.current[tab]) clearTimeout(scrollSaveTimers.current[tab]);
    scrollSaveTimers.current[tab] = setTimeout(() => {
      try {
        sessionStorage.setItem(`iam_bottom_scroll_${tab}`, String(el.scrollTop));
      } catch (_) {}
    }, 150);
  }, []);

  const onToggleShellMode = useCallback(() => {
    setShellMode((prev) => {
      const next = prev === "remote" ? "local" : "remote";
      try {
        localStorage.setItem(SHELL_PREF_KEY, next);
      } catch (_) {}
      return next;
    });
  }, []);

  useEffect(() => {
    if (!open || activeTab !== "terminal") {
      return;
    }
    const container = xtermContainerRef.current;
    if (!container) return;

    const style = getComputedStyle(document.documentElement);
    const term = new Terminal({
      termName: "xterm-256color",
      disableStdin: false,
      fontFamily: "monospace",
      fontSize: 13,
      cursorBlink: true,
      theme: {
        background: style.getPropertyValue("--bg-canvas").trim(),
        foreground: style.getPropertyValue("--color-text").trim(),
        cursor: style.getPropertyValue("--color-accent").trim(),
        selectionBackground: style.getPropertyValue("--color-primary").trim(),
        black: "#1e1200",
        brightBlack: style.getPropertyValue("--text-muted").trim(),
      },
    });
    const fitAddon = new FitAddon();
    const webLinksAddon = new WebLinksAddon();
    term.loadAddon(fitAddon);
    term.loadAddon(webLinksAddon);
    term.open(container);
    fitAddon.fit();
    term.focus();
    terminalXtermRef.current = term;

    // Wire every keystroke directly to PTY WebSocket
    term.onData((data) => {
      const ws = terminalWsRef.current;
      if (ws && ws.readyState === WebSocket.OPEN) {
        try { ws.send(JSON.stringify({ type: "input", data })); } catch (_) {}
      }
    });

    const ro = new ResizeObserver(() => {
      try {
        fitAddon.fit();
      } catch (_) {}
    });
    ro.observe(container);

    return () => {
      ro.disconnect();
      terminalXtermRef.current = null;
      term.dispose();
    };
  }, [open, activeTab, terminalUserReconnect]);

  useEffect(() => {
    if (!open || activeTab !== "terminal" || terminalSplitCount < 2) {
      if (terminalXterm2Ref.current) {
        try {
          terminalXterm2Ref.current.dispose();
        } catch (_) {}
        terminalXterm2Ref.current = null;
      }
      return;
    }
    const container = xtermContainer2Ref.current;
    if (!container) return;

    const style = getComputedStyle(document.documentElement);
    const term = new Terminal({
      termName: "xterm-256color",
      disableStdin: true,
      fontFamily: "monospace",
      fontSize: 13,
      cursorBlink: true,
      theme: {
        background: style.getPropertyValue("--bg-canvas").trim(),
        foreground: style.getPropertyValue("--color-text").trim(),
        cursor: style.getPropertyValue("--color-accent").trim(),
        selectionBackground: style.getPropertyValue("--color-primary").trim(),
        black: "#1e1200",
        brightBlack: style.getPropertyValue("--text-muted").trim(),
      },
    });
    const fitAddon = new FitAddon();
    const webLinksAddon = new WebLinksAddon();
    term.loadAddon(fitAddon);
    term.loadAddon(webLinksAddon);
    term.open(container);
    fitAddon.fit();
    terminalXterm2Ref.current = term;

    const ro = new ResizeObserver(() => {
      try {
        fitAddon.fit();
      } catch (_) {}
    });
    ro.observe(container);

    return () => {
      ro.disconnect();
      terminalXterm2Ref.current = null;
      term.dispose();
    };
  }, [open, activeTab, terminalUserReconnect, terminalSplitCount]);

  useEffect(() => {
    if (activeTab !== "terminal" || !open) return;
    let cancelled = false;
    const wsProto = typeof window !== "undefined" && window.location.protocol === "https:" ? "wss:" : "ws:";
    const wsHost = typeof window !== "undefined" ? window.location.host : "inneranimalmedia.com";
    const origin = typeof window !== "undefined" ? window.location.origin : "";
    const sameOriginPtyProxyUrl = `${wsProto}//${wsHost}/api/agent/terminal/ws`;
    setTerminalWsState("connecting");
    const term = terminalXtermRef.current;
    if (term) {
      term.clear();
      term.write(`\r\nConnecting to ${shellMode === "remote" ? "Remote" : "Local"}...\r\n`);
    }
    const term2 = terminalXterm2Ref.current;
    if (term2) {
      term2.clear();
      term2.write(`\r\nConnecting to ${shellMode === "remote" ? "Remote" : "Local"}...\r\n`);
    }

    (async () => {
      let targetUrl = "";
      if (shellMode === "remote") {
        try {
          const socketUrlEndpoint = origin ? `${origin}/api/agent/terminal/socket-url` : "/api/agent/terminal/socket-url";
          const r = await fetch(socketUrlEndpoint, {
            credentials: "include",
            cache: "no-store",
          });
          const j = await r.json().catch(() => ({}));
          if (cancelled) return;
          const normalized = normalizePtyWebSocketUrl(j?.url);
          if (r.ok && normalized) {
            targetUrl = normalized;
          } else {
            const detail =
              j && j.error != null
                ? String(j.error)
                : j && j.hint != null
                  ? String(j.hint)
                  : !normalized && j?.url != null
                    ? "url not a valid WebSocket address"
                    : "";
            writeAllXterms(
              `\r\nRemote shell unavailable (${r.ok ? "bad response" : `HTTP ${r.status}`})${detail ? `: ${detail}` : ""}.\r\n` +
                `If this persists, check /api/agent/terminal/socket-url while logged in.\r\n`
            );
            if (!cancelled) setTerminalWsState("error");
            return;
          }
        } catch (_) {
          if (cancelled) return;
          writeAllXterms("\r\nRemote shell unavailable (network error).\r\n");
          if (!cancelled) setTerminalWsState("error");
          return;
        }
      } else {
        targetUrl = sameOriginPtyProxyUrl;
      }
      if (cancelled) return;
      let ws = null;
      try {
        ws = new WebSocket(targetUrl);
        terminalWsRef.current = ws;
      } catch (_) {
        if (!cancelled) setTerminalWsState("error");
        return;
      }
      ws.onopen = () => {
        if (cancelled) return;
        if (terminalWsRef.current !== ws) return;
        setTerminalWsState("connected");
        writeAllXterms("\r\nConnected.\r\n");
      };
      ws.onmessage = (ev) => {
        if (cancelled) return;
        if (terminalWsRef.current !== ws) return;
        const raw = typeof ev.data === "string" ? ev.data : ev.data?.toString?.() ?? "";
        try {
          const msg = JSON.parse(raw);
          if (msg.type === "session_id") {
            terminalSessionIdRef.current = msg.session_id;
            return;
          }
          if (msg.type === "output" && msg.data) {
            writeAllXterms(msg.data);
            return;
          }
        } catch (_) {}
        writeAllXterms(raw);
      };
      ws.onclose = () => {
        if (cancelled) return;
        if (terminalWsRef.current !== ws) return;
        terminalWsRef.current = null;
        terminalSessionIdRef.current = null;
        [terminalXtermRef, terminalXterm2Ref].forEach((ref) => {
          const tt = ref.current;
          if (tt && !lastLineEndsWithDisconnected(tt)) {
            tt.write("\r\n[Disconnected]\r\n");
          }
        });
        setTerminalWsState("disconnected");
      };
      ws.onerror = () => {
        if (cancelled) return;
        if (terminalWsRef.current !== ws) return;
        setTerminalWsState("error");
      };
    })();

    return () => {
      cancelled = true;
      try {
        if (terminalWsRef.current) terminalWsRef.current.close();
      } catch (_) {}
      terminalWsRef.current = null;
    };
  }, [open, activeTab, terminalUserReconnect, shellMode, writeAllXterms]);

  useEffect(() => {
    if (activeTab === "terminal" && terminalInputRef.current) {
      terminalInputRef.current.focus();
    }
  }, [activeTab]);

  const runCommandInTerminal = useCallback(async (command, opts = {}) => {
    try {
      const res = await fetch("/api/agent/terminal/run", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          command: (command || "").trim(),
          session_id: terminalSessionIdRef.current ?? null,
        }),
      });
      const data = await res.json().catch(() => ({}));
      if (data.output) {
        writeAllXterms("\r\n" + data.output);
      }
      if (opts.focusTerminal !== false) {
        onTabChange("terminal");
      }
      return { ok: res.ok, output: data.output, error: data.error };
    } catch (err) {
      return { ok: false, error: err?.message ?? String(err) };
    }
  }, [onTabChange, writeAllXterms]);

  useEffect(() => {
    if (runCommandRunnerRef) {
      runCommandRunnerRef.current = { runCommandInTerminal };
      return () => {
        runCommandRunnerRef.current = null;
      };
    }
  }, [runCommandRunnerRef, runCommandInTerminal]);

  const sendTerminalKey = useCallback(
    (e) => {
      const isEnter = e.key === "Enter" || e.key === "NumpadEnter";
      if (!isEnter) return;
      e.preventDefault();
      e.stopPropagation();
      const ws = terminalWsRef.current;
      if (ws && ws.readyState === WebSocket.OPEN) {
        const line = terminalInput.trimEnd() + "\n";
        try {
          ws.send(JSON.stringify({ type: "input", data: line }));
        } catch (_) {
          return;
        }
        [terminalXtermRef, terminalXterm2Ref].forEach((ref) => {
          const tt = ref.current;
          if (!tt) return;
          const has = bufferHasVisibleText(tt);
          tt.write((has ? "" : "[ sam@iam ~ ]$ ") + terminalInput + "\r\n");
        });
        setTerminalInput("");
        return;
      }
      const cmd = terminalInput.trim();
      if (!cmd) return;
      void (async () => {
        [terminalXtermRef, terminalXterm2Ref].forEach((ref) => {
          const tt = ref.current;
          if (!tt) return;
          const has = bufferHasVisibleText(tt);
          tt.write((has ? "" : "[ sam@iam ~ ]$ ") + cmd + "\r\n");
        });
        setTerminalInput("");
        const r = await runCommandInTerminal(cmd);
        if (r && !r.ok) {
          const errLine = r.error ? String(r.error) : "Terminal run failed";
          writeAllXterms("\r\n" + errLine + "\r\n");
        }
      })();
    },
    [terminalInput, runCommandInTerminal, writeAllXterms]
  );

  const markQuick = useCallback((key, ok) => {
    setQuickRun((prev) => ({ ...prev, [key]: { at: new Date().toISOString(), ok: !!ok } }));
  }, []);

  useEffect(() => {
    if (activeTab !== "quick" || !open) return;
    let cancelled = false;
    fetch("/api/mcp/services/health", { credentials: "same-origin" })
      .then((r) => r.json())
      .then((d) => {
        if (!cancelled) setMcpQuickServices(Array.isArray(d.services) ? d.services : []);
      })
      .catch(() => {
        if (!cancelled) setMcpQuickServices([]);
      });
    return () => {
      cancelled = true;
    };
  }, [activeTab, open]);

  const runQuickWranglerLogin = useCallback(async () => {
    setQuickBusy("wrangler_login");
    try {
      const r = await runCommandInTerminal("wrangler login", { focusTerminal: false });
      const out = r && r.output != null ? String(r.output) : "";
      const url = extractFirstHttpUrl(out) || "https://dash.cloudflare.com/login";
      if (onOpenBrowserPanel) onOpenBrowserPanel(url);
      markQuick("wrangler_login", r && r.ok);
    } catch (_) {
      markQuick("wrangler_login", false);
    } finally {
      setQuickBusy(null);
    }
  }, [runCommandInTerminal, onOpenBrowserPanel, markQuick]);

  const runQuickTunnelRestart = useCallback(async () => {
    setQuickBusy("tunnel_restart");
    try {
      const res = await fetch("/api/tunnel/restart", { method: "POST", credentials: "same-origin" });
      const j = await res.json().catch(() => ({}));
      markQuick("tunnel_restart", res.ok && j && j.ok === true);
    } catch (_) {
      markQuick("tunnel_restart", false);
    } finally {
      setQuickBusy(null);
    }
  }, [markQuick]);

  const runQuickCloudflaredLogin = useCallback(async () => {
    setQuickBusy("cloudflared_login");
    try {
      const r = await runCommandInTerminal("cloudflared tunnel login", { focusTerminal: false });
      const out = r && r.output != null ? String(r.output) : "";
      const url = extractFirstHttpUrl(out) || "https://dash.cloudflare.com/login";
      if (onOpenBrowserPanel) onOpenBrowserPanel(url);
      markQuick("cloudflared_login", r && r.ok);
    } catch (_) {
      markQuick("cloudflared_login", false);
    } finally {
      setQuickBusy(null);
    }
  }, [runCommandInTerminal, onOpenBrowserPanel, markQuick]);

  const runQuickGitHubOAuth = useCallback(() => {
    try {
      const origin = typeof window !== "undefined" ? window.location.origin : "";
      const returnTo = typeof window !== "undefined" ? window.location.href : "";
      const url = `${origin}/api/oauth/github/start?returnTo=${encodeURIComponent(returnTo)}`;
      if (onOpenBrowserPanel) onOpenBrowserPanel(url);
      markQuick("github_oauth", true);
    } catch (_) {
      markQuick("github_oauth", false);
    }
  }, [onOpenBrowserPanel, markQuick]);

  const runQuickGitSync = useCallback(async () => {
    setQuickBusy("git_sync");
    try {
      const res = await fetch("/api/agent/git/sync", {
        method: "POST",
        credentials: "same-origin",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ session_id: agentSessionId != null ? String(agentSessionId) : null }),
      });
      const j = await res.json().catch(() => ({}));
      markQuick("git_sync", res.ok && j && j.proposal_id);
    } catch (_) {
      markQuick("git_sync", false);
    } finally {
      setQuickBusy(null);
    }
  }, [agentSessionId, markQuick]);

  const runQuickMcpWorkerProposal = useCallback(async () => {
    setQuickBusy("mcp_worker_restart");
    try {
      const res = await fetch("/api/agent/propose", {
        method: "POST",
        credentials: "same-origin",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          command_text:
            "cd inneranimalmedia-mcp-server && npx wrangler deploy -c wrangler.toml",
          command_name: "mcp_worker_restart",
          rationale: "Quick Actions: restart MCP worker (requires approval before run).",
          session_id: agentSessionId != null ? String(agentSessionId) : null,
        }),
      });
      const j = await res.json().catch(() => ({}));
      markQuick("mcp_worker_restart", res.ok && j && j.proposal_id);
    } catch (_) {
      markQuick("mcp_worker_restart", false);
    } finally {
      setQuickBusy(null);
    }
  }, [agentSessionId, markQuick]);

  const runMcpServiceReconnect = useCallback(async (svcId) => {
    const key = `mcp_ping_${svcId}`;
    setQuickBusy(key);
    try {
      const res = await fetch(`/api/mcp/services/${encodeURIComponent(svcId)}/ping`, {
        method: "POST",
        credentials: "same-origin",
      });
      const j = await res.json().catch(() => ({}));
      markQuick(key, res.ok && j && (j.health_status === "healthy" || j.health_status === "degraded"));
      const r2 = await fetch("/api/mcp/services/health", { credentials: "same-origin" });
      const d = await r2.json().catch(() => ({}));
      setMcpQuickServices(Array.isArray(d.services) ? d.services : []);
      setMcpHealth(d);
    } catch (_) {
      markQuick(key, false);
    } finally {
      setQuickBusy(null);
    }
  }, [markQuick]);

  useEffect(() => {
    if (activeTab !== "mcp" || !open) return;
    setMcpLoading(true);
