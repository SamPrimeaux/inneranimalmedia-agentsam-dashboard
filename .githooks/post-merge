#!/usr/bin/env bash
# Post-merge hook: after git pull/merge, upload to R2 autorag if knowledge or populate script changed.
# Optionally records the run to D1 ci_di_workflow_runs (see scripts/record-workflow-run.sh).
# Enable: git config core.hooksPath .githooks

set -e
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT" || exit 0

# Only run if relevant paths changed
if ! git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD 2>/dev/null | grep -qE '^docs/knowledge/|^scripts/populate-autorag\.sh'; then
  exit 0
fi

echo "[post-merge] docs/knowledge or populate-autorag.sh changed; running populate-autorag.sh..."
if ./scripts/populate-autorag.sh >> /tmp/autorag-post-merge.log 2>&1; then
  echo "[post-merge] Autorag upload completed. Run Sync in Cloudflare AI Search (iam-autorag) to update vectors."
  if [ -x "$REPO_ROOT/scripts/record-workflow-run.sh" ]; then
    "$REPO_ROOT/scripts/record-workflow-run.sh" autorag_sync success "post-merge" 2>/dev/null || true
  fi
else
  echo "[post-merge] Autorag upload failed. Check /tmp/autorag-post-merge.log"
  if [ -x "$REPO_ROOT/scripts/record-workflow-run.sh" ]; then
    "$REPO_ROOT/scripts/record-workflow-run.sh" autorag_sync failure "post-merge" 2>/dev/null || true
  fi
  exit 1
fi
