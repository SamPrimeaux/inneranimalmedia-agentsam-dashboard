// Sandbox Worker only: inneranimal-dashboard (Workers Builds / wrangler.jsonc).
// Workers Builds deploy command: npm run deploy:sandbox (see docs/SANDBOX_WORKERS_BUILDS.md).
// Production Worker (inneranimalmedia): ALWAYS deploy with -c wrangler.production.toml — never replace that file from here.
// R2: ASSETS + DASHBOARD → agent-sam-sandbox-cicd. AUTORAG/DOCS/R2/TOOLS use same bucket names as prod (TOOLS = Monaco/code).
// Queues omitted: same queue consumer cannot bind to two Workers; production inneranimalmedia keeps MY_QUEUE consumer.
//
// Optional secrets (wrangler secret put -c wrangler.jsonc) for *.workers.dev email/password form:
//   SANDBOX_DASHBOARD_PASSWORD — shared dev gate (plaintext; compared with timingSafeEqualUtf8).
//   OR SANDBOX_DASHBOARD_PBKDF2_SALT + SANDBOX_DASHBOARD_PBKDF2_HASH (hex, same PBKDF2-SHA256 100k as auth_users).
//   Optional SANDBOX_DASHBOARD_IMPERSONATE_USER — auth_users id/email to session as when gate matches (default: email from form).

{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "inneranimal-dashboard",
  "main": "src/index.js",
  "compatibility_date": "2026-01-20",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "preview_urls": true,
  "no_bundle": false,
  // Vite SPA bundle (must not use binding name "ASSETS" — that is the R2 bucket below).
  // run_worker_first: so GET / hits worker.js and serves R2 ASSETS index-v3.html (landing) instead of dist/index.html (IAM Explorer).
  "build": {
    "command": ""
  },
  "ai": {
    "binding": "AI"
  },
  "browser": {
    "binding": "MYBROWSER"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "inneranimalmedia-business",
      "database_id": "cf87b717-d4e2-4cf8-bab0-a81268e32d49"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ASSETS",
      "bucket_name": "agent-sam-sandbox-cicd"
    },
    {
      "binding": "DASHBOARD",
      "bucket_name": "agent-sam-sandbox-cicd"
    },
    {
      "binding": "AUTORAG_BUCKET",
      "bucket_name": "autorag"
    },
    {
      "binding": "DOCS_BUCKET",
      "bucket_name": "iam-docs"
    },
    {
      "binding": "R2",
      "bucket_name": "iam-platform"
    },
    {
      "binding": "TOOLS",
      "bucket_name": "tools"
    }
  ],
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "08183bb9d2914e87ac8395d7e4ecff60"
    }
  ],
  "vectorize": [
    {
      "binding": "VECTORIZE",
      "index_name": "ai-search-inneranimalmedia-aisearch"
    },
    {
      "binding": "VECTORIZE_INDEX",
      "index_name": "ai-search-iam-autorag"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "09438d5e4f664bf78467a15af7743c44"
    },
    {
      "binding": "SESSION_CACHE",
      "id": "dc87920b0a9247979a213c09df9a0234"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "IAM_COLLAB",
        "class_name": "IAMCollaborationSession"
      },
      {
        "name": "CHESS_SESSION",
        "class_name": "ChessRoom"
      },
      {
        "name": "AGENT_SESSION",
        "class_name": "AgentChatSqlV1"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v4",
      "new_sqlite_classes": ["IAMAgentSession"]
    },
    {
      "tag": "v5",
      "new_sqlite_classes": ["AgentChatSqlV1"]
    }
  ],
  "analytics_engine_datasets": [
    {
      "binding": "WAE",
      "dataset": "inneranimalmedia"
    }
  ],
  "triggers": {
    "crons": [
      "0 6 * * *",
      "30 13 * * *",
      "0 9 * * *",
      "*/30 * * * *",
      "0 0 * * *"
    ]
  },
  "vars": {
    "CLOUDFLARE_ACCOUNT_ID": "ede6590ac0d2fb7daf155b35653457b2",
    "CLOUDFLARE_IMAGES_ACCOUNT_HASH": "g7wf09fCONpnidkRnR_5vw",
    "GITHUB_CLIENT_ID": "Ov23li6BZYxjVtGUWibX",
    "GOOGLE_CLIENT_ID": "427617292678-gf3u47lpf876q7miq31hel2ms6tcr2f8.apps.googleusercontent.com",
    "TENANT_ID": "tenant_sam_primeaux",
    "SANDBOX_SIGNIN_FALLBACK_URL": "https://pub-0d103dec19f84813ab2d58b17153a95f.r2.dev/static/auth-signin.html",
    "WORKSPACE_ID": "ws_inneranimalmedia",
    "DEPLOY_ENV": "sandbox"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": true,
      "persist": true,
      "head_sampling_rate": 1
    }
  },
  "tail_consumers": [
    {
      "service": "inneranimalmedia-tail"
    }
  ]
}
