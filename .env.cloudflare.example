# Copy to .env.cloudflare and fill in. .env.cloudflare is gitignored.
# Used by scripts/with-cloudflare-env.sh for wrangler deploy / R2 uploads.
#
# CLOUDFLARE_ACCOUNT_ID=your_account_id_here
# CLOUDFLARE_API_TOKEN=your_api_token_here
#
# Optional: for deploy hooks / post-deploy calls (also set in Cloudflare Worker env)
# DEPLOY_HOOK_SECRET=your_deploy_hook_secret_here
