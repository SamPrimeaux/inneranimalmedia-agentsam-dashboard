# Inner Animal Media — local env reference (2026-03)
# ------------------------------------------------------------
# Copy to a gitignored file and fill secrets from YOUR vault:
#   cp .env.example .env.cloudflare
#   cp .env.example .env.local
#
# Never commit filled files. Cloudflare does not show secret values after upload;
# your only copies are what you saved (e.g. .env.secrets.recovery, 1Password).
#
# Worker secrets: ./scripts/with-cloudflare-env.sh npx wrangler secret put NAME -c wrangler.production.toml
# MCP secrets:    cd inneranimalmedia-mcp-server && ../scripts/with-cloudflare-env.sh npx wrangler secret put NAME -c wrangler.toml
#
# Plain [vars] below match wrangler.production.toml (committed). Bindings (R2, D1, KV, …) are not .env keys.

# =============================================================================
# Local CLI — required for ./scripts/with-cloudflare-env.sh
# =============================================================================
CLOUDFLARE_ACCOUNT_ID=ede6590ac0d2fb7daf155b35653457b2
CLOUDFLARE_API_TOKEN=

# Deploy logging (optional locally) — match Worker secret DEPLOY_TRACKING_TOKEN or WORKER_SECRET from vault; see docs/DEPLOY_TRACKING.md
DEPLOY_TRACKING_TOKEN=

# =============================================================================
# Cursor MCP (gitignored path: .cursor/mcp.json) — Bearer must match Worker secret MCP_AUTH_TOKEN
# Also set MCP_AUTH_TOKEN on BOTH inneranimalmedia and inneranimalmedia-mcp-server
# =============================================================================
MCP_AUTH_TOKEN=

# =============================================================================
# Main worker — plaintext vars (wrangler.production.toml [vars])
# =============================================================================
CLOUDFLARE_IMAGES_ACCOUNT_HASH=g7wf09fCONpnidkRnR_5vw
TENANT_ID=tenant_sam_primeaux
GITHUB_CLIENT_ID=Ov23li6BZYxjVtGUWibX
GOOGLE_CLIENT_ID=427617292678-gf3u47lpf876q7miq31hel2ms6tcr2f8.apps.googleusercontent.com

# =============================================================================
# Main worker — secrets (paste from vault into LOCAL file only; leave blank in git)
# Recent recovery session set many of these on the Worker; Cloudflare will not echo them back.
# =============================================================================
INTERNAL_API_SECRET=
WORKER_SECRET=
GITHUB_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_SECRET=
RESEND_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_AI_API_KEY=
AI_SEARCH_TOKEN=
AI_GATEWAY_TOKEN=
AI_GATEWAY_BASE_URL=
AI_GATEWAY_OPENAI_BASE_URL=
CF_AIG_TOKEN=
CLOUDFLARE_IMAGES_API_TOKEN=
CLOUDFLARE_IMAGES_TOKEN=
CLOUDFLARE_STREAM_TOKEN=
# Terminal: use ONE shared token for PTY_AUTH_TOKEN + TERMINAL_SECRET (+ MCP PTY_AUTH_TOKEN). See docs/TERMINAL_KEYS_RESET.md
PTY_AUTH_TOKEN=
TERMINAL_SECRET=
TERMINAL_WS_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
VAULT_MASTER_KEY=

# =============================================================================
# MCP worker — plain var (optional; defaults in code). PTY_AUTH_TOKEN / MCP_AUTH_TOKEN
# must also be set on inneranimalmedia-mcp-server if you use MCP terminal tools.
# =============================================================================
MAIN_WORKER_BASE_URL=https://inneranimalmedia.com

# =============================================================================
# Bindings (not .env): ASSETS, CAD_ASSETS, DASHBOARD, R2, DB, KV, SESSION_CACHE,
# VECTORIZE, VECTORIZE_INDEX, HYPERDRIVE, AI, AI_SEARCH, MYBROWSER, MY_QUEUE,
# WAE, IAM_COLLAB, CHESS_SESSION
# =============================================================================
